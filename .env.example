# Copy this file to .env and fill in the values before running in production.
# In development the defaults in settings.py are used if these are not set.

# Required in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of hostnames Django will serve, e.g. example.com,www.example.com
DJANGO_ALLOWED_HOSTS=

# PostgreSQL connection
DJANGO_DB_NAME=polls
DJANGO_DB_USER=polls
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
